# Copy this file to .env and replace each placeholder.
# .env is intentionally ignored by Git.
FIREBASE_API_KEY=replace-with-firebase-web-api-key
FIREBASE_ANDROID_APP_ID=replace-with-android-app-id
FIREBASE_WEB_APP_ID=replace-with-web-app-id
FIREBASE_IOS_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_AUTH_DOMAIN=replace-with-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket
FIREBASE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
FIREBASE_IOS_BUNDLE_ID=
RECAPTCHA_SITE_KEY=
